{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "country": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "monthly", "qtr", "6months", "yearly"] },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "trialExpiresAt": { "type": "string", "format": "date-time" },
        "planExpiresAt": { "type": "string", "format": "date-time" },
        "referrerId": { "type": "string" },
        "referralCode": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Signal": {
      "title": "Signal",
      "description": "A crypto trade signal broadcasted by admins.",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "bias": { "type": "string", "enum": ["Long", "Short"] },
        "entryZone": { "type": "string" },
        "stopLoss": { "type": "string" },
        "takeProfits": { "type": "array", "items": { "type": "string" } },
        "leverage": { "type": "string" },
        "duration": { "type": "string" },
        "riskRule": { "type": "string" },
        "priceAtSignal": { "type": "string" },
        "broadcastTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pair", "bias", "entryZone", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of a subscription payment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "originalAmount": { "type": "number" },
        "couponCode": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planId", "amount", "createdAt"]
    },
    "PayoutRequest": {
      "title": "PayoutRequest",
      "description": "A request for commission withdrawal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "accountDetails": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "paid", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "method", "status", "createdAt"]
    },
    "Commission": {
      "title": "Commission",
      "description": "Earned commission from a referral transaction.",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "transactionId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "cleared", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "transactionId", "amount", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon for checkout.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "pct": { "type": "number" },
        "fixed": { "type": "number" },
        "uses": { "type": "number" },
        "limit": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "isActive"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and meta-data."
    },
    "signals/{signalId}": {
      "schema": "Signal",
      "description": "Global signals feed."
    },
    "transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Payment records."
    },
    "payoutRequests/{requestId}": {
      "schema": "PayoutRequest",
      "description": "Withdrawal requests from referrers."
    },
    "commissions/{commissionId}": {
      "schema": "Commission",
      "description": "Referral earnings tracking."
    },
    "coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Promotional discount codes."
    }
  }
}
