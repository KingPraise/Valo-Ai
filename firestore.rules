rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // In this environment, email verified is usually true for Google/Auth providers.
      // But we strictly enforce it if required.
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             (data.whatsapp == null || (data.whatsapp is string && data.whatsapp.size() <= 32)) &&
             (data.country == null || (data.country is string && data.country.size() <= 64)) &&
             data.plan in ['free', 'monthly', 'qtr', '6months', 'yearly'] &&
             (data.status == null || data.status in ['active', 'expired']) &&
             data.createdAt == request.time;
    }

    function isValidSignal(data) {
      return data.pair is string && data.pair.size() <= 16 &&
             data.bias in ['Long', 'Short'] &&
             data.entryZone is string && data.entryZone.size() <= 128 &&
             data.createdAt == request.time;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.planId in ['monthly', 'qtr', '6months', 'yearly'] &&
             data.createdAt == request.time;
    }

    function isValidPayoutRequest(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 20 &&
             data.method is string && data.method.size() <= 64 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().isAdmin == false; // Forbid self-assigning admin
      
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'whatsapp', 'country']) &&
                        incoming().isAdmin == existing().isAdmin) || 
                       isAdmin();
    }

    match /signals/{signalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidSignal(incoming());
    }

    match /transactions/{txnId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidTransaction(incoming());
      // Transactions are immutable in this flow
      allow update, delete: if isAdmin();
    }

    match /payoutRequests/{requestId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidPayoutRequest(incoming());
      allow update: if isAdmin(); // Admin updates status
      allow delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow get: if isSignedIn() && (existing().referrerId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow write: if isAdmin(); // Only system/admin creates commissions
    }

    match /coupons/{couponId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
